{
  "name": "atlasl2",
  "description": "An interactive data engineering project showcasing L2 communicability across the world with a user-selected combination of languages.",
  "version": "0.1.3",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm run build -w @atlasl2/client",
    "build:server": "npm run build -w @atlasl2/server",
    "bump": "tsx --tsconfig scripts/tsconfig.scripts.json scripts/bump_version.ts",
    "data": "npm run data:combine && npm run data:expand && npm run data:metadata",
    "data:combine": "tsx --tsconfig scripts/tsconfig.scripts.json scripts/combine_datasets.ts",
    "data:expand": "tsx --tsconfig scripts/tsconfig.scripts.json scripts/expand_edges.ts",
    "data:metadata": "tsx --tsconfig scripts/tsconfig.scripts.json scripts/generate_metadata.ts",
    "data:delete": "cd data && rm -f combined_data.json combined_languages.json country_metadata.json language_metadata.json relation_map.json",
    "dev:client": "npm run dev -w @atlasl2/client",
    "dev:server": "npm run dev -w @atlasl2/server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "lint": "eslint .",
    "start": "npm run start -w @atlasl2/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ladjs/country-language": "^1.0.3",
    "@types/ladjs__country-language": "^1.0.0",
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "countries-list": "^3.3.0",
    "csv-parse": "^6.2.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "iso-639-3": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
